# GitHub ingestion
GITHUB_TOKEN=your_github_token_here

# LLM profile generation (OpenAI-compatible endpoint)
# Works with OpenAI, vLLM, Ollama, Together, DeepSeek, Moonshot, etc.
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4

# Embedding (OpenAI-compatible endpoint)
# Works with OpenAI, or a local bge-m3 served via vLLM / Infinity /
# Text Embeddings Inference / Xinference / LocalAI, etc.
# For a local server, set EMBEDDING_BASE_URL to your endpoint and
# EMBEDDING_API_KEY to any non-empty placeholder if it requires no auth.
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
